<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:paddingTop="40dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@null"
            android:textColor="@color/ink3"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textAllCaps="false"
            android:text="← BACK"
            android:padding="0dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHOTO PROOF"
            android:textColor="@color/accent"
            android:textSize="10sp"
            android:letterSpacing="0.15" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/rule" />

    <!-- Viewfinder -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/ink" />

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/rule" />

    <!-- Status + capture -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink2"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_capture"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/ink"
            android:textColor="@color/paper"
            android:textSize="15sp"
            android:letterSpacing="0.03"
            android:textAllCaps="false"
            android:text="Capture Photo" />

    </LinearLayout>

</LinearLayout>
