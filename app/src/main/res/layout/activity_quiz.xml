<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/paper" android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="24dp" android:paddingTop="40dp" android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="QUIZ" android:textColor="@color/accent"
            android:textSize="10sp" android:letterSpacing="0.15"/>
        <TextView android:id="@+id/tv_progress" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/ink3"
            android:textSize="12sp" android:fontFamily="monospace"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/rule"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="24dp">

            <TextView android:id="@+id/tv_question" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/ink"
                android:textSize="17sp" android:lineSpacingMultiplier="1.5"
                android:textStyle="bold" android:layout_marginBottom="28dp"/>

            <Button android:id="@+id/btn_option_0" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:backgroundTint="@color/ink"
                android:textColor="@color/paper" android:textAllCaps="false"
                android:gravity="start|center_vertical" android:paddingStart="16dp"
                android:layout_marginBottom="10dp" android:minHeight="52dp"/>
            <Button android:id="@+id/btn_option_1" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:backgroundTint="@color/ink"
                android:textColor="@color/paper" android:textAllCaps="false"
                android:gravity="start|center_vertical" android:paddingStart="16dp"
                android:layout_marginBottom="10dp" android:minHeight="52dp"/>
            <Button android:id="@+id/btn_option_2" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:backgroundTint="@color/ink"
                android:textColor="@color/paper" android:textAllCaps="false"
                android:gravity="start|center_vertical" android:paddingStart="16dp"
                android:layout_marginBottom="10dp" android:minHeight="52dp"/>
            <Button android:id="@+id/btn_option_3" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:backgroundTint="@color/ink"
                android:textColor="@color/paper" android:textAllCaps="false"
                android:gravity="start|center_vertical" android:paddingStart="16dp"
                android:layout_marginBottom="24dp" android:minHeight="52dp"/>

            <TextView android:id="@+id/tv_feedback" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="14sp"
                android:lineSpacingMultiplier="1.5" android:visibility="invisible"
                android:layout_marginBottom="20dp"/>

            <Button android:id="@+id/btn_next" android:layout_width="match_parent"
                android:layout_height="56dp" android:backgroundTint="@color/accent"
                android:textColor="@color/paper" android:textSize="15sp"
                android:textAllCaps="false" android:visibility="gone" android:text="Next →"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
