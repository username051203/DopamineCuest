<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHIELD ACTIVE"
            android:textColor="@color/accent"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Not yet."
                android:textColor="@color/ink"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"/>

            <TextView
                android:id="@+id/tv_blocked_pkg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ink3"
                android:textSize="10sp"
                android:letterSpacing="0.1"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Complete a task to earn access, or reason with the coach."
            android:textColor="@color/ink2"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_coach_chat"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:backgroundTint="@color/rule"
            android:textColor="@color/accent"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:text="Reason with Coach →"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/rule"/>

    <!-- Allowed apps grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALLOWED APPS"
            android:textColor="@color/ink3"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:paddingStart="24dp"
            android:layout_marginBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_allowed_apps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/rule"/>

    <!-- Access active panel -->
    <LinearLayout
        android:id="@+id/layout_access_active"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACCESS WINDOW"
            android:textColor="@color/ink3"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_access_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/accent"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="-0.03"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Shield restores automatically when time expires."
            android:textColor="@color/ink3"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_use_apps"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/ink"
            android:textColor="@color/paper"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:text="Use your apps →"/>

    </LinearLayout>

    <!-- Task list -->
    <LinearLayout
        android:id="@+id/layout_task_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMPLETE A TASK"
            android:textColor="@color/ink3"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:paddingStart="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tasks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp"/>

    </LinearLayout>

</LinearLayout>
