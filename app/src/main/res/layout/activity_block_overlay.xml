<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="36dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHIELD ACTIVE"
            android:textColor="@color/accent"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Not yet."
                android:textColor="@color/ink"
                android:textSize="26sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"/>

            <TextView
                android:id="@+id/tv_blocked_pkg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ink3"
                android:textSize="10sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_coach_chat"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/rule"
            android:textColor="@color/accent"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:text="Reason with Coach →"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/rule"/>

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/tab_apps"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="ALLOWED APPS"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:background="@color/ink"
            android:textColor="@color/paper"
            android:elevation="0dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/rule"/>

        <Button
            android:id="@+id/tab_tasks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="COMPLETE TASK"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:background="@color/rule"
            android:textColor="@color/ink3"
            android:elevation="0dp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/rule"/>

    <!-- Main panels container -->
    <FrameLayout
        android:id="@+id/layout_main"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Allowed apps panel -->
        <LinearLayout
            android:id="@+id/panel_apps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_allowed_apps"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="8dp"/>

        </LinearLayout>

        <!-- Tasks panel -->
        <LinearLayout
            android:id="@+id/panel_tasks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tasks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Access active overlay (shown when window earned) -->
    <LinearLayout
        android:id="@+id/layout_access_active"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/paper"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_access_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/accent"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_use_apps"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="@color/ink"
            android:textColor="@color/paper"
            android:textAllCaps="false"
            android:text="Open apps →"/>

    </LinearLayout>

</LinearLayout>
